---
import { buildLandingJsonLd } from "@lib/seo/structured-data";
import type { Variant } from "@lib/data/variants";

interface Props {
  // Page-level overrides. When unset we fall back to `variant.seo.*` and
  // finally to the hard-coded Build Space defaults. This lets the
  // `index.astro` call site stay unchanged while variant-driven pages
  // (resolved at request time) automatically pick up their own copy.
  title?: string;
  description?: string;
  canonical?: string;
  ogImage?: string;
  noIndex?: boolean;
  jsonLd?: object;
  // Active variant. Drives the default title/description/og image and
  // controls whether non-default variant URLs are excluded from search.
  variant?: Variant;
}

const {
  title,
  description,
  canonical,
  ogImage,
  noIndex,
  jsonLd,
  variant,
} = Astro.props;

const site = Astro.site?.toString().replace(/\/$/, "") ?? "https://buildspace.in";

const finalTitle =
  title ?? variant?.seo.title ?? "Build Space — Live AI Cohort for Class 9 to 12 Students in India";
const finalDescription =
  description ??
  variant?.seo.description ??
  "A four-week live cohort for Indian Class 9 to 12 students. Build and deploy a working AI agent in Python.";
const finalOgImage = ogImage ?? variant?.seo.ogImage ?? "/og-cover.png";

// Variant URLs must canonical-tag back to the bare homepage so they do not
// compete with `/` in search results. Explicit `canonical` prop still wins.
const canonicalUrl = canonical ?? new URL("/", site).toString();
const ogImageUrl = finalOgImage.startsWith("http") ? finalOgImage : `${site}${finalOgImage}`;

// Non-default variants are excluded from indexing — same canonical, but
// search engines should never surface the `?ad=...` URL directly.
const shouldNoIndex = noIndex === true || (variant !== undefined && variant.slug !== "default");

const ld = jsonLd ?? buildLandingJsonLd(site, variant);
---

<title>{finalTitle}</title>
<meta name="description" content={finalDescription} />
<meta name="theme-color" content="#fbf9f4" />
<meta name="format-detection" content="telephone=no" />
<link rel="canonical" href={canonicalUrl} />

{shouldNoIndex && <meta name="robots" content="noindex,nofollow" />}
{!shouldNoIndex && <meta name="robots" content="index,follow,max-image-preview:large,max-snippet:-1" />}

<!-- Open Graph -->
<meta property="og:type" content="website" />
<meta property="og:site_name" content="Build Space" />
<meta property="og:title" content={finalTitle} />
<meta property="og:description" content={finalDescription} />
<meta property="og:url" content={canonicalUrl} />
<meta property="og:image" content={ogImageUrl} />
<meta property="og:image:width" content="1200" />
<meta property="og:image:height" content="630" />
<meta property="og:locale" content="en_IN" />

<!-- Twitter -->
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={finalTitle} />
<meta name="twitter:description" content={finalDescription} />
<meta name="twitter:image" content={ogImageUrl} />

<!-- Icons -->
<link rel="icon" href="/favicon.svg" type="image/svg+xml" />
<link rel="apple-touch-icon" href="/apple-touch-icon.png" />
<link rel="manifest" href="/site.webmanifest" />

<!-- Fonts: preconnect for performance, swap for non-blocking paint -->
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link rel="preconnect" href="https://api.fontshare.com" crossorigin />
<link
  rel="preload"
  as="style"
  href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&display=swap"
/>
<link
  rel="stylesheet"
  href="https://fonts.googleapis.com/css2?family=Bricolage+Grotesque:opsz,wght@12..96,400;12..96,500;12..96,600;12..96,700&display=swap"
/>
<link
  rel="stylesheet"
  href="https://api.fontshare.com/v2/css?f[]=general-sans@400,500,600&display=swap"
/>

<!-- JSON-LD -->
<script is:inline type="application/ld+json" set:html={JSON.stringify(ld)} />
