---
import { COHORT } from "@lib/data/cohort";
import PayDemoButton from "@components/payment/PayDemoButton";
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}

const { variant } = Astro.props;
const s = variant.scholarship;
---

<section
  id="scholarship"
  aria-labelledby="scholarship-heading"
  class="section-pad"
  style="background: var(--color-paper);"
>
  <div class="container-page">
    <div
      class="reveal relative overflow-hidden rounded-[var(--radius-xl)] border"
      style="border-color: color-mix(in oklch, var(--color-accent) 28%, var(--color-rule)); background: var(--color-accent-soft);"
    >
      <!-- Warm accent glow, echoing the hero + validation washes -->
      <div
        aria-hidden="true"
        class="pointer-events-none absolute -right-24 -top-24"
        style="width: 460px; height: 460px; background: radial-gradient(circle, color-mix(in oklch, var(--color-accent) 22%, transparent) 0%, transparent 60%); filter: blur(6px);"
      ></div>

      <div class="relative grid items-center gap-10 p-8 md:grid-cols-12 md:gap-12 md:p-12">
        <!-- LEFT: the merit message -->
        <div class="md:col-span-7">
          <p class="eyebrow" style="color: var(--color-accent-deep);">
            <span
              aria-hidden="true"
              class="mr-2 inline-block h-1.5 w-1.5 rounded-full align-middle"
              style="background: var(--color-accent);"
            ></span>
            {s.bannerEyebrow}
          </p>

          <h2
            id="scholarship-heading"
            class="mt-4"
            style={`font-family: var(--font-display); font-size: var(--text-3xl); line-height: 1.06; letter-spacing: -0.02em; color: var(--color-ink);`}
          >
            {s.bannerHeadline}
          </h2>

          <p
            class="mt-5 max-w-2xl"
            style={`color: color-mix(in oklch, var(--color-ink) 78%, var(--color-accent-deep)); font-size: var(--text-lg); line-height: 1.55;`}
          >
            {s.bannerBody}
          </p>

          <ul
            class="mt-7 flex flex-wrap gap-2.5"
            style="list-style: none; padding: 0; margin: 0;"
          >
            {s.points.map((p) => (
              <li
                class="inline-flex items-center gap-2 rounded-[var(--radius-pill)] px-3.5 py-1.5"
                style={`background: color-mix(in oklch, var(--color-paper) 70%, transparent); color: var(--color-accent-deep); font-size: var(--text-xs); font-weight: 500;`}
              >
                <span aria-hidden="true">→</span>
                {p}
              </li>
            ))}
          </ul>
        </div>

        <!-- RIGHT: pricing card — full price visible first, then ₹99 entry -->
        <div class="md:col-span-5">
          <div
            class="overflow-hidden rounded-[var(--radius-lg)] border"
            style="background: var(--color-paper); border-color: var(--color-rule);"
          >
            <!-- Price range — full price to scholarship floor -->
            <div
              class="px-7 py-5 text-center"
              style="background: var(--color-paper-soft); border-bottom: 1px solid var(--color-rule);"
            >
              <p
                class="text-xs uppercase tracking-[0.14em]"
                style="color: var(--color-ink-mute);"
              >
                Full cohort
              </p>
              <div class="mt-1.5 flex items-center justify-center gap-3">
                <span
                  style={`font-family: var(--font-display); font-size: var(--text-3xl); letter-spacing: -0.03em; font-weight: 600; color: var(--color-ink);`}
                >
                  {COHORT.priceDisplay}
                </span>
                <span aria-hidden="true" style="color: var(--color-ink-mute); font-size: var(--text-sm);">→</span>
                <span
                  style={`font-family: var(--font-display); font-size: var(--text-3xl); letter-spacing: -0.03em; font-weight: 600; color: var(--color-good);`}
                >
                  {COHORT.scholarshipPriceDisplay}
                </span>
              </div>
              <p
                class="mt-1"
                style={`color: var(--color-ink-mute); font-size: var(--text-xs);`}
              >
                for strong performers in the demo class
              </p>
            </div>

            <!-- ₹99 entry -->
            <div class="p-7 text-center">
              <p
                class="text-xs uppercase tracking-[0.14em]"
                style="color: var(--color-ink-mute);"
              >
                Your entry
              </p>
              <div class="mt-2 flex items-baseline justify-center gap-2">
                <span
                  style={`font-family: var(--font-display); font-size: var(--text-4xl); letter-spacing: -0.04em; font-weight: 600; color: var(--color-ink);`}
                >
                  ₹99
                </span>
                <span style={`color: var(--color-ink-mute); font-size: var(--text-base);`}>demo class</span>
              </div>
              <p
                class="mt-3"
                style={`color: var(--color-ink-soft); font-size: var(--text-sm); line-height: 1.5;`}
              >
                {s.line}
              </p>

              <div class="mt-6 flex justify-center">
                <PayDemoButton client:visible label={s.bannerCta} kind="accent" variant={variant.slug} />
              </div>

              <p
                class="mt-5 text-xs"
                style="color: var(--color-ink-mute);"
              >
                {COHORT.seatsRemaining} of {COHORT.batchSize} seats remaining
              </p>
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>
</section>
