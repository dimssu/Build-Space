---
import PayDemoButton from "@components/payment/PayDemoButton";
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}

const { variant } = Astro.props;
---

<section
  id="top"
  aria-labelledby="hero-headline"
  class="relative overflow-hidden"
  style="background: var(--color-paper);"
>
  <!-- Soft warm-light wash behind the hero copy. Pure decoration. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-0"
    style="background:
      radial-gradient(60% 80% at 100% 0%, color-mix(in oklch, var(--color-accent) 18%, transparent) 0%, transparent 60%),
      radial-gradient(70% 90% at -10% 100%, color-mix(in oklch, var(--color-warn) 14%, transparent) 0%, transparent 55%);"
  ></div>

  <!-- Faint grid that fades out as you scroll. Adds depth without noise. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0 -z-0"
    style="background-image:
      linear-gradient(color-mix(in oklch, var(--color-ink) 6%, transparent) 1px, transparent 1px),
      linear-gradient(90deg, color-mix(in oklch, var(--color-ink) 6%, transparent) 1px, transparent 1px);
      background-size: 56px 56px;
      mask-image: linear-gradient(180deg, black 0%, black 55%, transparent 100%);"
  ></div>

  <div
    class="container-page relative grid items-center gap-10 md:gap-16 lg:gap-20 lg:grid-cols-12"
    style="min-height: calc(100vh - 64px); padding-block: clamp(3rem, 2rem + 4vw, 6rem);"
  >
    <!-- LEFT: copy column -->
    <div class="lg:col-span-7">
      <p class="eyebrow reveal" style="color: var(--color-accent-deep);">
        <span
          aria-hidden="true"
          class="mr-2 inline-block h-1.5 w-1.5 rounded-full align-middle"
          style="background: var(--color-accent);"
        ></span>
        {variant.eyebrow}
      </p>

      {variant.hero.lines && variant.hero.lines.length > 0 ? (
        <h1
          id="hero-headline"
          class="hero-lines mt-6"
          style={`font-family: var(--font-display); line-height: 1.05; letter-spacing: -0.03em; font-weight: 600;`}
        >
          {variant.hero.lines.map((line, i) => (
            <span
              class="hero-line reveal"
              style={`--reveal-delay: ${80 + i * 140}ms; display: block; color: ${line.tone === "accent" ? "var(--color-accent-deep)" : "var(--color-ink)"}; font-weight: ${line.tone === "accent" ? 600 : 500};`}
            >
              {line.strikethrough ? (
                <span
                  class="hero-strike"
                  style={`--strike-delay: ${80 + i * 140 + 520}ms;`}
                >
                  {line.text}
                </span>
              ) : (
                line.text
              )}
            </span>
          ))}
        </h1>
      ) : (
        <h1
          id="hero-headline"
          class:list={[
            "reveal mt-5",
            variant.hero.size === "compact" && "hero-compact",
          ]}
          style={variant.hero.size === "compact"
            ? `font-family: var(--font-display); line-height: 1.08; letter-spacing: -0.03em; font-weight: 600; --reveal-delay: 80ms;`
            : `font-family: var(--font-display); font-size: var(--text-hero); line-height: 0.98; letter-spacing: -0.04em; font-weight: 600; --reveal-delay: 80ms;`}
        >
          {variant.hero.headline}
          <span
            style="display: block; color: var(--color-ink-soft); font-weight: 500;"
          >
            {variant.hero.headlineRest}
          </span>
        </h1>
      )}

      <p
        class="reveal mt-7 max-w-xl"
        style={`font-size: var(--text-lg); color: var(--color-ink-soft); line-height: 1.55; --reveal-delay: 160ms;`}
      >
        {variant.hero.subhead}
      </p>

      <div
        class="reveal mt-9 flex flex-wrap items-center gap-3"
        style="--reveal-delay: 240ms;"
      >
        <PayDemoButton client:idle label={variant.hero.primaryCta} kind="accent" fontSize="var(--text-sm)" variant={variant.slug} />
        <a href="#curriculum" class="btn btn-secondary" style="font-size: var(--text-sm);">
          {variant.hero.secondaryCta}
          <span aria-hidden="true" style="display: inline-block; transform: translateX(0); transition: transform 200ms var(--ease-out-quart);">→</span>
        </a>
      </div>

      <p
        class="reveal mt-5"
        style={`color: var(--color-ink-mute); font-size: var(--text-sm); --reveal-delay: 300ms;`}
      >
        {variant.hero.footnote}
      </p>

      <!-- Scholarship pill — the merit-not-money message, surfaced above the fold -->
      <a
        href="#scholarship"
        class="reveal mt-4 inline-flex items-center gap-2 rounded-[var(--radius-pill)] px-3.5 py-1.5 transition-colors"
        style={`background: var(--color-accent-soft); color: var(--color-accent-deep); font-size: var(--text-xs); font-weight: 500; --reveal-delay: 340ms;`}
      >
        <span aria-hidden="true">★</span>
        {variant.scholarship.pill}
      </a>

      <!-- Outcome chips — the answer to "what does my child walk out with?" -->
      <dl
        class="reveal mt-12 grid gap-4 sm:grid-cols-3"
        style="--reveal-delay: 380ms;"
      >
        {variant.hero.outcomes.map((o) => (
          <div
            class="rounded-[var(--radius-md)] border p-4"
            style="background: color-mix(in oklch, var(--color-paper-card) 92%, transparent); border-color: var(--color-rule); backdrop-filter: blur(4px);"
          >
            <dt
              style={`font-family: var(--font-display); font-size: var(--text-base); font-weight: 600; color: var(--color-ink);`}
            >
              {o.label}
            </dt>
            <dd
              class="mt-1"
              style={`color: var(--color-ink-mute); font-size: var(--text-xs);`}
            >
              {o.note}
            </dd>
          </div>
        ))}
      </dl>
    </div>

    <!-- RIGHT: photographic column with parallax + floating tags -->
    <div class="relative lg:col-span-5">
      <figure
        class="reveal relative"
        style="--reveal-delay: 200ms;"
      >
        <div
          data-parallax="0.35"
          class="relative overflow-hidden"
          style="
            border-radius: var(--radius-xl);
            border: 1px solid var(--color-rule);
            aspect-ratio: 4/5;
            box-shadow: 0 30px 80px -30px color-mix(in oklch, var(--color-ink) 30%, transparent),
                        0 8px 24px -12px color-mix(in oklch, var(--color-ink) 20%, transparent);
            transform: translate3d(0, var(--py, 0), 0);
            will-change: transform;
          "
        >
          <picture>
            <source srcset="/images/student-building.avif" type="image/avif" />
            <source srcset="/images/student-building.webp" type="image/webp" />
            <img
              src="/images/student-building.webp"
              alt="A fifteen-year-old student in a sunlit Indian home, focused on a laptop, typing the first lines of an AI agent."
              width="1800"
              height="2250"
              fetchpriority="high"
              decoding="async"
              style="width: 100%; height: 100%; object-fit: cover; object-position: center;"
            />
          </picture>

          <!-- Soft warm gradient inside the photo card to harmonise it with the page -->
          <div
            aria-hidden="true"
            class="pointer-events-none absolute inset-0"
            style="background: linear-gradient(160deg, transparent 50%, color-mix(in oklch, var(--color-ink) 28%, transparent) 100%);"
          ></div>
        </div>

        <!-- Floating credibility chips — small, restrained, parent-readable -->
        <div
          aria-hidden="true"
          class="absolute -left-4 top-6 hidden rounded-[var(--radius-pill)] border px-3 py-2 sm:flex"
          style="background: var(--color-paper); border-color: var(--color-rule); box-shadow: 0 8px 24px -12px color-mix(in oklch, var(--color-ink) 22%, transparent); font-size: var(--text-xs); color: var(--color-ink); font-weight: 500;"
        >
          <span
            class="mr-2 inline-block h-2 w-2 rounded-full"
            style="background: var(--color-good);"
          ></span>
          Class 9 to 12 · India
        </div>

        <div
          aria-hidden="true"
          class="absolute -right-3 bottom-10 hidden rounded-[var(--radius-md)] border p-3 sm:block"
          style="background: var(--color-paper); border-color: var(--color-rule); box-shadow: 0 8px 24px -12px color-mix(in oklch, var(--color-ink) 22%, transparent);"
        >
          <span
            style={`font-family: var(--font-display); font-size: var(--text-xl); font-weight: 600; color: var(--color-accent-deep); letter-spacing: -0.02em; line-height: 1; display: block;`}
          >
            5
          </span>
          <span
            style={`font-size: var(--text-2xs); color: var(--color-ink-mute); letter-spacing: 0.08em; text-transform: uppercase;`}
          >
            students per cohort
          </span>
        </div>
      </figure>
    </div>
  </div>

  <!-- Quiet "scroll" affordance at the bottom -->
  <div
    aria-hidden="true"
    class="absolute inset-x-0 bottom-5 flex justify-center"
  >
    <span
      class="inline-flex items-center gap-2 text-[10px] uppercase tracking-[0.2em]"
      style="color: var(--color-ink-mute);"
    >
      Scroll
      <span
        style="display: inline-block; width: 1px; height: 28px; background: linear-gradient(180deg, var(--color-ink-mute) 0%, transparent 100%); animation: scrollHint 1.8s var(--ease-out-quart) infinite;"
      ></span>
    </span>
  </div>
</section>

<style>
  @keyframes scrollHint {
    0%   { transform: translateY(-6px); opacity: 0; }
    35%  { opacity: 1; }
    100% { transform: translateY(8px);  opacity: 0; }
  }
  @media (prefers-reduced-motion: reduce) {
    @keyframes scrollHint { 0%, 100% { transform: none; opacity: 0.6; } }
  }

  /* Multi-line hero font sizing. Each line in `hero.lines` renders as its own
     row (display: block via inline style), so the overall block is tall. We
     use a tighter clamp than --text-hero so a 4-line stack fits within one
     viewport on phones and laptops without each line wrapping. */
  .hero-lines,
  .hero-compact {
    font-size: clamp(2.1rem, 1.2rem + 4.2vw, 4.25rem);
  }
  @media (min-width: 1024px) {
    .hero-lines,
    .hero-compact {
      font-size: clamp(2.5rem, 1rem + 3.6vw, 4.5rem);
    }
  }

  /* Animated strikethrough used inside .hero-line for "closed the tab"-style
     lines. inline-block bounds the ::after to the actual text width so the
     strike doesn't drift when the line is the only content of the row. */
  .hero-strike {
    position: relative;
    display: inline-block;
    max-width: 100%;
  }
  .hero-strike::after {
    content: "";
    position: absolute;
    left: 0;
    right: 0;
    top: 50%;
    height: 0.07em;
    margin-top: 0.02em;
    background: currentColor;
    transform-origin: left center;
    transform: scaleX(0);
    animation: heroStrike 600ms var(--ease-out-quart) forwards;
    animation-delay: var(--strike-delay, 700ms);
    border-radius: 999px;
    opacity: 0.95;
    pointer-events: none;
  }
  @keyframes heroStrike {
    from { transform: scaleX(0); }
    to   { transform: scaleX(1); }
  }
  @media (prefers-reduced-motion: reduce) {
    .hero-strike::after { animation: none; transform: scaleX(1); }
  }
</style>
