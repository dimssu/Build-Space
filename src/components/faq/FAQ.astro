---
import { COHORT } from "@lib/data/cohort";
import FAQItem from "./FAQItem.tsx";

// Parent-coded questions surface first; student-coded ones follow.
const parentFaqs = COHORT.faqs.filter((f) => f.forParent);
const studentFaqs = COHORT.faqs.filter((f) => !f.forParent);
---

<section
  id="faq"
  aria-labelledby="faq-heading"
  class="section-pad"
  style="background: var(--color-paper);"
>
  <div class="container-page">
    <div class="grid items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-5">
        <p class="eyebrow reveal">Honest answers</p>
        <h2
          id="faq-heading"
          class="reveal mt-4"
          style={`font-size: var(--text-3xl); --reveal-delay: 80ms;`}
        >
          The questions parents actually ask.
        </h2>
      </div>
      <p
        class="reveal md:col-span-7"
        style={`color: var(--color-ink-soft); font-size: var(--text-lg); --reveal-delay: 140ms;`}
      >
        If a question is not here, the answer is: write to <a href={`mailto:${COHORT.contact.email}`} style="color: var(--color-accent-deep); text-decoration: underline; text-underline-offset: 4px;">{COHORT.contact.email}</a> and a human replies. We do not have a bot.
      </p>
    </div>

    <div class="mt-14 grid gap-12 md:grid-cols-2">
      <div class="reveal" style="--reveal-delay: 200ms;">
        <p
          class="text-xs uppercase tracking-[0.14em]"
          style="color: var(--color-ink-mute);"
        >
          For parents
        </p>
        <div class="mt-4 border-t" style="border-color: var(--color-rule);">
          {parentFaqs.map((f, i) => (
            <FAQItem client:visible question={f.q} answer={f.a} defaultOpen={i === 0} />
          ))}
        </div>
      </div>

      <div class="reveal" style="--reveal-delay: 260ms;">
        <p
          class="text-xs uppercase tracking-[0.14em]"
          style="color: var(--color-ink-mute);"
        >
          For students
        </p>
        <div class="mt-4 border-t" style="border-color: var(--color-rule);">
          {studentFaqs.map((f) => (
            <FAQItem client:visible question={f.q} answer={f.a} />
          ))}
        </div>
      </div>
    </div>
  </div>
</section>
