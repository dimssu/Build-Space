---
import { COHORT, type Faq } from "@lib/data/cohort";
import FAQItem from "./FAQItem.tsx";
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}

const { variant } = Astro.props;

// Per-variant FAQ override (e.g. Hinglish for class11-hi). When unset,
// renders the canonical English FAQs from cohort.ts.
const sourceFaqs: Faq[] = (variant.faqs as Faq[] | undefined) ?? (COHORT.faqs as readonly Faq[] as Faq[]);

// Filter by audience. Render-order is decided by `variant.faqPriority`:
// the first entry's group comes first, the second's comes second.
const parentFaqs: Faq[] = sourceFaqs.filter((f) => f.forParent);
const studentFaqs: Faq[] = sourceFaqs.filter((f) => !f.forParent);

const groups: Record<"parent" | "student", { label: string; items: Faq[] }> = {
  parent: {
    label: variant.faq?.parentGroupLabel ?? "For parents",
    items: parentFaqs,
  },
  student: {
    label: variant.faq?.studentGroupLabel ?? "For students",
    items: studentFaqs,
  },
};

// Drop any empty group — keeps the layout clean when a variant supplies a
// fully audience-targeted FAQ list (e.g. class11-hi is student-only).
const order = variant.faqPriority.filter((key) => groups[key].items.length > 0);

const eyebrow = variant.faq?.eyebrow ?? "Honest answers";
const headline = variant.faq?.headline ?? "The questions parents actually ask.";
const supporting = variant.faq?.supporting;
---

<section
  id="faq"
  aria-labelledby="faq-heading"
  class="section-pad"
  style="background: var(--color-paper);"
>
  <div class="container-page">
    <div class="grid items-end gap-10 md:grid-cols-12">
      <div class="md:col-span-5">
        <p class="eyebrow reveal">{eyebrow}</p>
        <h2
          id="faq-heading"
          class="reveal mt-4"
          style={`font-size: var(--text-3xl); --reveal-delay: 80ms;`}
        >
          {headline}
        </h2>
      </div>
      <p
        class="reveal md:col-span-7"
        style={`color: var(--color-ink-soft); font-size: var(--text-lg); --reveal-delay: 140ms;`}
      >
        {supporting ? (
          <Fragment set:html={supporting} />
        ) : (
          <Fragment>
            If a question is not here, the answer is: write to <a href={`mailto:${COHORT.contact.email}`} style="color: var(--color-accent-deep); text-decoration: underline; text-underline-offset: 4px;">{COHORT.contact.email}</a> and a human replies. We do not have a bot.
          </Fragment>
        )}
      </p>
    </div>

    <div
      class:list={[
        "faq-grid",
        order.length > 1 ? "faq-grid-cols-2" : "faq-grid-cols-1",
      ]}
    >
      {order.map((key, idx) => (
        <div class="reveal" style={`--reveal-delay: ${200 + idx * 60}ms;`}>
          <p class="faq-group-label">
            <span aria-hidden="true" class="faq-group-dot"></span>
            {groups[key].label}
            <span aria-hidden="true" class="faq-group-count">{groups[key].items.length}</span>
          </p>
          <div class="faq-list">
            {groups[key].items.map((f, i) => (
              <FAQItem client:visible question={f.q} answer={f.a} defaultOpen={idx === 0 && i === 0} />
            ))}
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

<style>
  .faq-grid {
    display: grid;
    margin-top: 3.5rem;
    gap: clamp(2rem, 1rem + 3vw, 3.5rem);
  }
  @media (min-width: 768px) {
    .faq-grid-cols-2 { grid-template-columns: 1fr 1fr; }
  }

  .faq-group-label {
    display: inline-flex;
    align-items: center;
    gap: 0.6rem;
    font-size: 0.7rem;
    font-weight: 600;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: var(--color-ink);
    margin-bottom: 1.25rem;
  }
  .faq-group-dot {
    display: inline-block;
    width: 0.4rem;
    height: 0.4rem;
    border-radius: 999px;
    background: var(--color-accent);
  }
  .faq-group-count {
    margin-left: 0.15rem;
    padding: 0.1rem 0.5rem;
    border-radius: 999px;
    background: var(--color-accent-soft);
    color: var(--color-accent-deep);
    font-size: 0.65rem;
    letter-spacing: 0.04em;
    font-weight: 600;
  }

  /* Vertical stack of FAQ cards with a clean gap between each. */
  .faq-list {
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
  }

  .faq-list :global(.faq-card:hover) {
    border-color: color-mix(in srgb, var(--color-accent) 30%, var(--color-rule-strong)) !important;
  }
  .faq-list :global(.faq-card[data-open="false"]:hover) {
    background: color-mix(in srgb, var(--color-accent-soft) 18%, var(--color-paper)) !important;
  }
</style>
