---
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}

const { variant } = Astro.props;

// Render nothing when the variant has no validation block.
// This keeps the section purely opt-in per ad.
const v = variant.validation;
const badge = variant.cohortBadge;
---

{v && (
  <section
    id="validation"
    aria-label="A note before we go further"
    class="relative"
    style="background: var(--color-paper-soft); border-block: 1px solid var(--color-rule); padding-block: clamp(4rem, 3rem + 4vw, 7rem);"
  >
    <!-- A single, restrained band of warm tone — visually quieter than the hero,
         so it feels like a breath before the page resumes selling. -->
    <div
      aria-hidden="true"
      class="pointer-events-none absolute inset-0 -z-0"
      style="background:
        radial-gradient(45% 60% at 12% 0%, color-mix(in oklch, var(--color-warn) 10%, transparent) 0%, transparent 65%);"
    ></div>

    <div class="container-page relative">
      <div class="max-w-3xl">
        {(v.eyebrow || badge) && (
          <div class="reveal flex flex-wrap items-center gap-3">
            {v.eyebrow && (
              <p
                class="eyebrow"
                style="color: var(--color-accent-deep); margin: 0;"
              >
                <span
                  aria-hidden="true"
                  class="mr-2 inline-block h-1.5 w-1.5 rounded-full align-middle"
                  style="background: var(--color-accent);"
                ></span>
                {v.eyebrow}
              </p>
            )}
            {badge && (
              <span
                class="inline-flex items-center gap-2"
                style={`padding: 0.35rem 0.7rem; border-radius: var(--radius-pill); border: 1px solid ${badge.tone === "accent" ? "var(--color-accent)" : "var(--color-rule-strong)"}; background: var(--color-paper); font-size: var(--text-2xs); letter-spacing: 0.06em; text-transform: uppercase; color: ${badge.tone === "accent" ? "var(--color-accent-deep)" : "var(--color-ink-soft)"}; font-weight: 600;`}
              >
                <span
                  aria-hidden="true"
                  class="inline-block h-1.5 w-1.5 rounded-full"
                  style={`background: ${badge.tone === "accent" ? "var(--color-accent)" : "var(--color-good)"};`}
                ></span>
                {badge.text}
              </span>
            )}
          </div>
        )}

        <p
          class="reveal mt-5"
          style={`font-family: var(--font-display); font-size: var(--text-3xl); line-height: 1.15; letter-spacing: -0.02em; color: var(--color-ink); font-weight: 500; --reveal-delay: 80ms;`}
        >
          {v.headline}
        </p>

        {v.body && (
          <div class="mt-6 max-w-2xl grid gap-4">
            {(Array.isArray(v.body) ? v.body : [v.body]).map((para, i) => (
              <p
                class="reveal"
                style={`color: var(--color-ink-soft); font-size: var(--text-lg); line-height: 1.55; --reveal-delay: ${180 + i * 80}ms;`}
              >
                {para}
              </p>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>
)}
