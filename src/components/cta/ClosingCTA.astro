---
import { COHORT } from "@lib/data/cohort";
import PayDemoButton from "@components/payment/PayDemoButton";
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}

const { variant } = Astro.props;

// Convert literal "\n" line breaks in the variant headline into <br /> so an
// ad variant can author multi-line CTAs without authoring HTML.
const closingHeadlineHtml = variant.closing.headline.replace(/\n/g, "<br />");
---

<section
  id="apply"
  aria-labelledby="apply-heading"
  class="section-pad-lg relative overflow-hidden"
  style="background: var(--color-ink); color: var(--color-paper);"
>
  <!-- Cinematic demo-day still as the section backdrop -->
  <picture aria-hidden="true">
    <source srcset="/images/demo-day.avif" type="image/avif" />
    <source srcset="/images/demo-day.webp" type="image/webp" />
    <img
      src="/images/demo-day.webp"
      alt=""
      width="1800"
      height="1200"
      loading="lazy"
      decoding="async"
      class="pointer-events-none absolute inset-0 h-full w-full object-cover"
      style="opacity: 0.85; filter: saturate(1.0) contrast(1.05);"
    />
  </picture>
  <!-- Edge feathering — very light darkening at the very top + bottom only so
       the image meets the rest of the page cleanly. Image dominates the rest. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0"
    style="background: linear-gradient(180deg, color-mix(in oklch, var(--color-ink) 55%, transparent) 0%, transparent 18%, transparent 82%, color-mix(in oklch, var(--color-ink) 55%, transparent) 100%);"
  ></div>
  <!-- Spotlight: a focused dark ellipse behind the centred copy so the headline
       and body always read. Edges of the band stay bright and show the image. -->
  <div
    aria-hidden="true"
    class="pointer-events-none absolute inset-0"
    style="background: radial-gradient(50% 60% at 50% 50%, color-mix(in oklch, var(--color-ink) 92%, transparent) 0%, color-mix(in oklch, var(--color-ink) 75%, transparent) 40%, color-mix(in oklch, var(--color-ink) 30%, transparent) 75%, transparent 100%);"
  ></div>
  <div
    aria-hidden="true"
    class="pointer-events-none absolute -bottom-40 left-1/2 -translate-x-1/2"
    style="width: 700px; height: 700px; background: radial-gradient(circle, color-mix(in oklch, var(--color-accent) 24%, transparent) 0%, transparent 60%); filter: blur(8px);"
  ></div>

  <div class="container-page relative">
    <div
      class="mx-auto max-w-2xl text-center"
      style="text-shadow: 0 2px 24px color-mix(in oklch, var(--color-ink) 85%, transparent), 0 1px 4px color-mix(in oklch, var(--color-ink) 65%, transparent);"
    >
      <p
        class="eyebrow reveal"
        style="color: color-mix(in oklch, var(--color-paper) 92%, transparent); max-width: none; width: 100%;"
      >
        <span
          aria-hidden="true"
          class="mr-2 inline-block h-1.5 w-1.5 rounded-full align-middle"
          style="background: var(--color-accent);"
        ></span>
        {variant.closing.eyebrow}
      </p>

      <h2
        id="apply-heading"
        class="reveal mt-5"
        style={`font-family: var(--font-display); font-size: var(--text-4xl); line-height: 1.04; letter-spacing: -0.03em; color: var(--color-paper); font-weight: 600; --reveal-delay: 80ms;`}
        set:html={closingHeadlineHtml}
      />

      <p
        class="reveal mx-auto mt-6 max-w-xl"
        style={`color: var(--color-paper); opacity: 0.95; font-size: var(--text-lg); line-height: 1.55; --reveal-delay: 140ms;`}
      >
        {variant.closing.body}
      </p>

      <div class="reveal mt-9 flex flex-wrap justify-center gap-3" style="--reveal-delay: 200ms;">
        <PayDemoButton client:idle label={variant.hero.primaryCta} kind="accent" variant={variant.slug} />
        <a
          href={`mailto:${COHORT.contact.email}`}
          class="btn"
          style="color: var(--color-paper); border: 1px solid color-mix(in oklch, var(--color-paper) 45%, transparent); background: color-mix(in oklch, var(--color-ink) 30%, transparent); backdrop-filter: blur(2px);"
        >
          Talk to the instructor
        </a>
      </div>

      <div class="reveal mt-6 flex justify-center" style="--reveal-delay: 240ms;">
        <a
          href="#scholarship"
          class="inline-flex items-center gap-2 rounded-[var(--radius-pill)] px-3.5 py-1.5 transition-colors"
          style={`border: 1px solid color-mix(in oklch, var(--color-accent) 70%, transparent); background: color-mix(in oklch, var(--color-accent) 18%, transparent); color: var(--color-paper); font-size: var(--text-xs); font-weight: 500; letter-spacing: 0.01em; white-space: nowrap; backdrop-filter: blur(2px);`}
        >
          <span aria-hidden="true" style="color: var(--color-accent);">★</span>
          {variant.scholarship.pill}
        </a>
      </div>

      <p
        class="reveal mt-8 text-sm"
        style={`color: color-mix(in oklch, var(--color-paper) 82%, transparent); max-width: none; width: 100%; --reveal-delay: 300ms;`}
      >
        {COHORT.batchSize} students, hard limit · Class 9 to 12, India · Cohort 01 starts {COHORT.startDateReadable}
      </p>
    </div>
  </div>
</section>
