---
import { COHORT } from "@lib/data/cohort";
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}

// `variant.brandTag.text` is "Build Space" by default. The visual wordmark in
// the footer logo uses "buildspace" (the brand mark) — left as-is. We accept
// the prop so the footer is wired for future copy variants.
const { variant: _variant } = Astro.props;

const year = new Date().getFullYear();
---

<footer
  class="border-t"
  style="background: var(--color-paper); border-color: var(--color-rule); padding-block: 4rem 3rem;"
  aria-labelledby="footer-heading"
>
  <h2 id="footer-heading" class="sr-only" style="position: absolute; clip-path: inset(50%); width: 1px; height: 1px; overflow: hidden;">
    Build Space contact and legal
  </h2>

  <div class="container-page grid gap-10 md:grid-cols-12">
    <div class="md:col-span-5">
      <a href="/" class="flex items-center gap-2.5" aria-label="Build Space — Logic Labs home">
        <span class="flex items-baseline gap-1 text-[18px] font-medium tracking-tight" style="font-family: var(--font-display);">
          <span style="color: var(--color-accent);">{'{'}</span>
          <span>buildspace</span>
          <span style="color: var(--color-accent);">{'}'}</span>
        </span>
        <span aria-hidden="true" style="width: 1px; height: 16px; background: var(--color-rule-strong);"></span>
        <span class="text-[11px] uppercase tracking-[0.14em]" style="color: var(--color-ink-mute);">Logic Labs</span>
      </a>
      <p class="mt-4 max-w-sm" style={`color: var(--color-ink-soft); font-size: var(--text-sm);`}>
        Build AI. Not just use it. A live cohort by Logic Labs for Class 9 to 12 students in India.
      </p>
      <p
        class="mt-4 inline-flex items-center gap-2 rounded-[var(--radius-pill)] px-3 py-1.5"
        style={`background: var(--color-accent-soft); color: var(--color-accent-deep); font-size: var(--text-xs); font-weight: 500;`}
      >
        <span aria-hidden="true">★</span>
        Merit scholarships in the ₹99 demo class
      </p>
    </div>

    <div class="md:col-span-3">
      <p class="text-xs uppercase tracking-[0.14em]" style="color: var(--color-ink-mute);">Contact</p>
      <ul class="mt-3 grid gap-2" style="list-style: none; padding: 0; font-size: var(--text-sm);">
        <li>
          <a href={`mailto:${COHORT.contact.email}`} style="color: var(--color-ink-soft);" class="hover:underline">{COHORT.contact.email}</a>
        </li>
        <li style="color: var(--color-ink-soft);">{COHORT.contact.whatsapp} (WhatsApp for parents)</li>
      </ul>
    </div>

    <div class="md:col-span-4">
      <p class="text-xs uppercase tracking-[0.14em]" style="color: var(--color-ink-mute);">Cohort</p>
      <ul class="mt-3 grid gap-2" style="list-style: none; padding: 0; font-size: var(--text-sm); color: var(--color-ink-soft);">
        <li>{COHORT.cohort}</li>
        <li>Starts {COHORT.startDateReadable}</li>
        <li>{COHORT.batchSize} students, weekends only</li>
        <li><a href="/#scholarship" style="color: var(--color-accent-deep);" class="hover:underline">Scholarships decided on merit</a></li>
      </ul>
    </div>
  </div>

  <div class="container-page mt-10 flex flex-wrap items-center justify-between gap-4 border-t pt-6" style="border-color: var(--color-rule);">
    <p style={`color: var(--color-ink-mute); font-size: var(--text-xs);`}>
      © {year} Build Space. All rights reserved.
    </p>
    <nav class="flex items-center gap-5" aria-label="Legal">
      <a href="/privacy" class="hover:underline" style="color: var(--color-ink-mute); font-size: var(--text-xs);">Privacy Policy</a>
      <a href="/terms" class="hover:underline" style="color: var(--color-ink-mute); font-size: var(--text-xs);">Terms &amp; Conditions</a>
    </nav>
  </div>
</footer>
