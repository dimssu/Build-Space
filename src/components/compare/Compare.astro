---
// Four side-by-side comparisons, the highest-leverage differences for a parent
// trying to figure out whether this is different from the other AI courses
// they have seen advertised. Said plainly, no names.
const rows = [
  {
    question: "What language does your child actually write?",
    them: "Drag-and-drop blocks. Pretend code that doesn't run anywhere real.",
    us: "Real Python. The same language used to build production AI systems.",
  },
  {
    question: "Who is teaching the class?",
    them: "A rotating pool of CS graduates who learned AI to teach it.",
    us: "One active AI engineer, every session, who knows your child by week one.",
  },
  {
    question: "How long is each session?",
    them: "45 minutes. Not enough to actually finish anything.",
    us: "Two hours. Long enough to ship something every single time.",
  },
  {
    question: "What does your child walk out with?",
    them: "A PDF certificate and a vague sense of having attended.",
    us: "A deployed AI agent, a live URL, and a GitHub repository they own.",
  },
];
---

<section
  id="why"
  aria-labelledby="why-heading"
  class="section-pad"
  style="background: var(--color-paper-soft); border-block: 1px solid var(--color-rule);"
>
  <div class="container-page grid items-end gap-10 md:grid-cols-12 md:gap-16">
    <div class="md:col-span-7">
      <p class="eyebrow reveal">The honest comparison</p>
      <h2
        id="why-heading"
        class="reveal mt-4"
        style={`font-size: var(--text-3xl); --reveal-delay: 80ms; line-height: 1.04;`}
      >
        Everyone says they teach AI.<br />
        <span style="color: var(--color-ink-soft); font-weight: 500;">Almost no one teaches this.</span>
      </h2>
      <p
        class="reveal mt-6 max-w-xl"
        style={`color: var(--color-ink-soft); font-size: var(--text-lg); --reveal-delay: 140ms;`}
      >
        Four questions a parent should ask any AI course before paying for it. Logic Labs answers each one differently from the rest of the market, on purpose.
      </p>
    </div>

    <figure
      class="reveal md:col-span-5"
      style="--reveal-delay: 200ms;"
    >
      <div
        class="overflow-hidden"
        style="border-radius: var(--radius-lg); border: 1px solid var(--color-rule); aspect-ratio: 4/3; background: var(--color-paper-card);"
      >
        <picture>
          <source srcset="/images/parents-laptop.avif" type="image/avif" />
          <source srcset="/images/parents-laptop.webp" type="image/webp" />
          <img
            src="/images/parents-laptop.webp"
            alt="An Indian father and mother sit together at a dining table, reading a laptop screen by warm evening light."
            width="1600"
            height="1200"
            loading="lazy"
            decoding="async"
            style="width: 100%; height: 100%; object-fit: cover;"
          />
        </picture>
      </div>
      <figcaption
        class="mt-3"
        style="color: var(--color-ink-mute); font-size: var(--text-xs); letter-spacing: 0.04em;"
      >
        Built for the parents we wanted to answer.
      </figcaption>
    </figure>
  </div>

  <div class="container-page mt-14">
    <ol class="grid gap-5" style="list-style: none; padding: 0; margin: 0;">
      {rows.map((r, i) => (
        <li
          class="reveal grid gap-px overflow-hidden rounded-[var(--radius-lg)] border md:grid-cols-12"
          style={`background: var(--color-rule); border-color: var(--color-rule); --reveal-delay: ${i * 80}ms;`}
        >
          <div
            class="p-6 md:col-span-4"
            style="background: var(--color-paper-card);"
          >
            <p
              class="text-xs uppercase tracking-[0.12em]"
              style="color: var(--color-ink-mute);"
            >
              Question {String(i + 1).padStart(2, "0")}
            </p>
            <p
              class="mt-2"
              style={`font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; color: var(--color-ink); line-height: 1.2;`}
            >
              {r.question}
            </p>
          </div>

          <div
            class="p-6 md:col-span-4"
            style="background: var(--color-paper);"
          >
            <p
              class="text-xs uppercase tracking-[0.12em]"
              style="color: var(--color-ink-mute);"
            >
              Most AI courses
            </p>
            <p
              class="mt-2"
              style={`color: var(--color-ink-soft); font-size: var(--text-base); line-height: 1.5;`}
            >
              {r.them}
            </p>
          </div>

          <div
            class="p-6 md:col-span-4"
            style="background: color-mix(in oklch, var(--color-accent-soft) 50%, var(--color-paper-card));"
          >
            <p
              class="text-xs uppercase tracking-[0.12em]"
              style="color: var(--color-accent-deep); font-weight: 500;"
            >
              Logic Labs
            </p>
            <p
              class="mt-2"
              style={`color: var(--color-ink); font-size: var(--text-base); line-height: 1.5; font-weight: 500;`}
            >
              {r.us}
            </p>
          </div>
        </li>
      ))}
    </ol>
  </div>
</section>
