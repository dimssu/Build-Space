---
import { COHORT } from "@lib/data/cohort";

const points = [
  {
    title: "One person, every session",
    desc: "Not a pool of rotating tutors. The instructor knows your child's name, their gaps, and their pace by week one.",
  },
  {
    title: "Available any day of the week",
    desc: "If your child gets stuck on a Tuesday night, they can ask. This is not a pre-recorded course with a comment section.",
  },
  {
    title: "Answers the question textbooks don't",
    desc: "\"How does this actually work in a product people use?\" gets a real answer from someone who has shipped it.",
  },
  {
    title: "Backed by a team",
    desc: "Backup instructors on standby. If something comes up, the session is rescheduled or covered. The cohort never stops.",
  },
];
---

<section
  id="instructor"
  aria-labelledby="instructor-heading"
  class="section-pad"
  style="background: var(--color-paper-soft); border-block: 1px solid var(--color-rule);"
>
  <div class="container-page">
    <div class="max-w-3xl">
      <p class="eyebrow reveal">The instructor</p>
      <h2
        id="instructor-heading"
        class="reveal mt-4"
        style={`font-size: var(--text-3xl); --reveal-delay: 80ms;`}
      >
        Not a teacher who learned AI. A practitioner who showed up.
      </h2>
    </div>

    <div class="mt-14 grid gap-10 md:grid-cols-12 md:gap-16">
      <figure
        class="reveal md:col-span-5"
        style="--reveal-delay: 140ms;"
      >
        <div
          class="overflow-hidden"
          style="border-radius: var(--radius-lg); border: 1px solid var(--color-rule); aspect-ratio: 4/5; background: var(--color-paper-card);"
        >
          <img
            src="/images/instructor.webp"
            alt="The Build Space instructor, an AI engineer in their mid-twenties, photographed in a clean home workspace."
            loading="lazy"
            decoding="async"
            width="800"
            height="1000"
            style="width: 100%; height: 100%; object-fit: cover;"
          />
        </div>
        <figcaption
          class="mt-5 grid gap-1"
          style="color: var(--color-ink-soft); font-size: var(--text-sm);"
        >
          <span style="color: var(--color-ink); font-weight: 600;">{COHORT.instructor.name}</span>
          <span>{COHORT.instructor.role}</span>
        </figcaption>

        <ul class="mt-5 flex flex-wrap gap-2" style="list-style: none; padding: 0;">
          {COHORT.instructor.credentials.map((c) => (
            <li>
              <span
                class="inline-flex items-center"
                style={`padding: 0.35rem 0.7rem; border-radius: var(--radius-pill); border: 1px solid var(--color-rule-strong); color: var(--color-ink-soft); font-size: var(--text-2xs);`}
              >
                {c}
              </span>
            </li>
          ))}
        </ul>
      </figure>

      <div class="md:col-span-7">
        <blockquote
          class="reveal border-l-2 pl-6"
          style="--reveal-delay: 200ms; border-color: var(--color-accent);"
        >
          <p
            style={`font-family: var(--font-display); font-size: var(--text-2xl); line-height: 1.25; color: var(--color-ink); font-weight: 500;`}
          >
            "I build AI systems for a living. I looked at what was being taught to school students in India and realised nobody was showing them the real thing. So I started Logic Labs."
          </p>
        </blockquote>

        <ul class="mt-10 grid gap-7" style="list-style: none; padding: 0;">
          {points.map((p, i) => (
            <li
              class="reveal grid grid-cols-12 gap-5 border-t pt-7"
              style={`border-color: var(--color-rule); --reveal-delay: ${260 + i * 80}ms;`}
            >
              <div class="col-span-12 sm:col-span-4">
                <h3 style={`font-size: var(--text-base); font-weight: 600; color: var(--color-ink);`}>
                  {p.title}
                </h3>
              </div>
              <div class="col-span-12 sm:col-span-8">
                <p style={`color: var(--color-ink-soft); font-size: var(--text-base);`}>{p.desc}</p>
              </div>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </div>
</section>
