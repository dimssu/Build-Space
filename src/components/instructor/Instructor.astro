---
import { COHORT } from "@lib/data/cohort";
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}

const { variant } = Astro.props;

const points = [
  {
    title: "One person, every session",
    desc: "Not a pool of rotating tutors. The instructor knows your child's name, their gaps, and their pace by week one.",
  },
  {
    title: "Available any day of the week",
    desc: "If your child gets stuck on a Tuesday night, they can ask. This is not a pre-recorded course with a comment section.",
  },
  {
    title: "Answers the question textbooks don't",
    desc: '"How does this actually work in a product people use?" gets a real answer from someone who has shipped it.',
  },
  {
    title: "Backed by a team",
    desc: "Backup instructors on standby. If something comes up, the session is rescheduled or covered. The cohort never stops.",
  },
];
---

<section
  id="instructor"
  aria-labelledby="instructor-heading"
  class="section-pad"
  style="background: var(--color-paper-soft); border-block: 1px solid var(--color-rule);"
>
  <div class="container-page">

    <!-- Section label + headline -->
    <div class="max-w-3xl">
      <p class="eyebrow reveal">{variant.instructor.eyebrow}</p>
      <h2
        id="instructor-heading"
        class="reveal mt-4"
        style={`font-size: var(--text-3xl); --reveal-delay: 80ms;`}
      >
        {variant.instructor.headline}
      </h2>
    </div>

    <!-- Quote block — the dominant visual -->
    <div class="reveal mt-14" style="--reveal-delay: 160ms;">
      <blockquote style="max-width: 52rem;">
        <p
          style={`font-family: var(--font-display); font-size: clamp(1.75rem, 1.3rem + 2vw, 3rem); line-height: 1.15; letter-spacing: -0.025em; color: var(--color-ink); font-weight: 500;`}
        >
          {variant.instructor.lead}
        </p>
      </blockquote>

      <!-- Attribution strip -->
      <div
        class="mt-7 flex flex-wrap items-center gap-x-5 gap-y-3 pt-6"
        style="border-top: 1px solid var(--color-rule);"
      >
        <div class="flex items-center gap-3 flex-wrap">
          <span
            style="font-size: var(--text-base); font-weight: 600; color: var(--color-ink);"
          >
            {COHORT.instructor.name}
          </span>
          <span aria-hidden="true" style="color: var(--color-rule-strong); font-size: var(--text-sm);">·</span>
          <span style="color: var(--color-ink-soft); font-size: var(--text-sm);">
            {COHORT.instructor.role}
          </span>
        </div>

        {variant.instructor.showLinks && COHORT.instructor.links && COHORT.instructor.links.length > 0 && (
          <ul
            class="flex items-center gap-3 ml-auto"
            style="list-style: none; padding: 0;"
            aria-label="Instructor profiles"
          >
            {COHORT.instructor.links.map((link) => (
              <li>
                <a
                  href={link.href}
                  target="_blank"
                  rel="noopener noreferrer me"
                  class="inline-flex items-center gap-1"
                  style={`color: var(--color-accent-deep); font-size: var(--text-sm); font-weight: 500; text-decoration: none; transition: opacity 150ms;`}
                  onmouseover="this.style.opacity='0.7'"
                  onmouseout="this.style.opacity='1'"
                >
                  {link.label}
                  <span aria-hidden="true" style="font-size: 0.8em;">↗</span>
                </a>
              </li>
            ))}
          </ul>
        )}
      </div>

      <!-- Credential chips -->
      <ul class="mt-4 flex flex-wrap gap-2" style="list-style: none; padding: 0;">
        {COHORT.instructor.credentials.map((c) => (
          <li>
            <span
              style={`display: inline-flex; align-items: center; padding: 0.3rem 0.7rem; border-radius: var(--radius-pill); border: 1px solid var(--color-rule-strong); color: var(--color-ink-soft); font-size: var(--text-xs);`}
            >
              {c}
            </span>
          </li>
        ))}
      </ul>
    </div>

    <!-- Shipped work card (optional) -->
    {variant.instructor.showShippedWork && COHORT.instructor.shippedWork && (
      <div class="reveal mt-8" style="--reveal-delay: 220ms;">
        <a
          href={COHORT.instructor.shippedWork.href}
          target="_blank"
          rel="noopener noreferrer"
          class="block"
          style={`display: inline-flex; flex-direction: column; gap: var(--s-1); padding: 0.9rem 1.1rem; border-radius: var(--radius-md); border: 1px solid var(--color-rule-strong); background: var(--color-paper); text-decoration: none; min-width: 220px; max-width: 320px; transition: border-color 200ms var(--ease-out-quart), background 200ms var(--ease-out-quart);`}
          onmouseover="this.style.borderColor='var(--color-accent)'; this.style.background='color-mix(in oklch, var(--color-accent) 5%, var(--color-paper))'"
          onmouseout="this.style.borderColor='var(--color-rule-strong)'; this.style.background='var(--color-paper)'"
        >
          <div
            style="display: flex; align-items: center; justify-content: space-between; gap: var(--s-3); font-size: var(--text-2xs); letter-spacing: 0.08em; text-transform: uppercase; color: var(--color-ink-mute); font-weight: 600;"
          >
            <span>Shipped in production</span>
            <span aria-hidden="true" style="color: var(--color-accent-deep);">↗</span>
          </div>
          <div
            style={`font-family: var(--font-display); font-size: var(--text-lg); font-weight: 600; color: var(--color-ink); letter-spacing: -0.01em;`}
          >
            {COHORT.instructor.shippedWork.label}
          </div>
          {COHORT.instructor.shippedWork.summary && (
            <div style={`color: var(--color-ink-soft); font-size: var(--text-sm); line-height: 1.45;`}>
              {COHORT.instructor.shippedWork.summary}
            </div>
          )}
        </a>
      </div>
    )}

    <!-- Trust points — 2-column grid -->
    <ul
      class="mt-14 grid md:grid-cols-2"
      style="list-style: none; padding: 0; gap: 0;"
    >
      {points.map((p, i) => (
        <li
          class="reveal grid grid-cols-12 gap-4 border-t py-7"
          style={`border-color: var(--color-rule); --reveal-delay: ${280 + i * 70}ms; ${i % 2 === 0 ? "padding-right: clamp(0px, 3vw, 2.5rem);" : "padding-left: clamp(0px, 3vw, 2.5rem);"}`}
        >
          <div class="col-span-12 sm:col-span-5">
            <h3 style={`font-size: var(--text-base); font-weight: 600; color: var(--color-ink);`}>
              {p.title}
            </h3>
          </div>
          <div class="col-span-12 sm:col-span-7">
            <p style={`color: var(--color-ink-soft); font-size: var(--text-base);`}>{p.desc}</p>
          </div>
        </li>
      ))}
    </ul>

  </div>
</section>
