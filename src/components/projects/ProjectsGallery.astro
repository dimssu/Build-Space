---
import { COHORT } from "@lib/data/cohort";
import type { Variant } from "@lib/data/variants";

interface Props {
  variant: Variant;
}
const { variant: _variant } = Astro.props;
---

<section
  id="projects"
  aria-labelledby="projects-heading"
  class="projects-section"
>
  <!-- Header -->
  <div class="projects-header container-page">
    <p class="eyebrow reveal">What gets built</p>
    <h2
      id="projects-heading"
      class="reveal mt-3"
      style="--reveal-delay: 80ms; font-size: var(--text-3xl); line-height: 1.06; letter-spacing: -0.025em; max-width: 22ch;"
    >
      Not toy examples. Working agents.
    </h2>
  </div>

  <!-- Gallery track -->
  <!-- IMPORTANT: no `data-lenis-prevent*` here. We need Lenis to keep
       receiving wheel events so the page can keep scrolling vertically when
       the user wheels over the gallery (e.g. at the horizontal edges). The
       wheel handler below only `preventDefault()`s when it is actually
       converting wheel→horizontal; otherwise the event bubbles to Lenis. -->
  <div
    class="projects-outer"
    role="list"
    aria-label="Project examples"
    tabindex="0"
  >
    <div class="projects-track">
      {COHORT.projects.map((project, i) => (
        <article
          class="project-card reveal"
          role="listitem"
          style={`--reveal-delay: ${140 + i * 55}ms;`}
        >
          <!-- Terminal — the full visual card -->
          <div class="pcard-win">
            <!-- Traffic lights only; week chip floats in corner -->
            <div class="pcard-bar" aria-hidden="true">
              <span class="dot" style="background:oklch(0.60 0.20 25);"></span>
              <span class="dot" style="background:oklch(0.70 0.16 72);"></span>
              <span class="dot" style="background:oklch(0.60 0.18 142);"></span>
            </div>

            <div class="pcard-body" aria-hidden="true">
              {project.terminal.map((line) => (
                <div
                  class:list={[
                    "tl",
                    (line.startsWith(">") || line.startsWith("$")) && "tl-cmd",
                    line.startsWith("✓") && "tl-ok",
                    line.startsWith("[") && "tl-sys",
                  ]}
                >
                  {line || "​"}
                </div>
              ))}
            </div>

            <!-- Week badge — absolute overlay -->
            <span class="week-chip" aria-hidden="true">{project.week}</span>
          </div>

          <!-- Label beneath the visual — Dribbble style -->
          <div class="pcard-label">
            <h3 class="pcard-title">{project.title}</h3>
            <ul class="pcard-tags" aria-label="Technologies">
              {project.tech.map((t) => <li>{t}</li>)}
            </ul>
          </div>
        </article>
      ))}

      <div class="track-end" aria-hidden="true"></div>
    </div>
  </div>

  <!-- Scroll hint -->
  <p class="scroll-hint-row" aria-hidden="true">
    <span>
      <svg width="12" height="12" viewBox="0 0 12 12" fill="none">
        <path d="M1.5 6h9M7 2.5l3.5 3.5L7 9.5" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" stroke-linejoin="round"/>
      </svg>
      Drag or scroll to explore
    </span>
  </p>
</section>

<style>
  /* ── Section ──────────────────────────────────────────── */
  .projects-section {
    background: var(--color-paper);
    border-top: 1px solid var(--color-rule);
    border-bottom: 1px solid var(--color-rule);
    overflow-x: clip;
    /* Inter-section breathing room so the gallery has air around it relative
       to the section above and below. */
    padding-block: clamp(3rem, 2rem + 3vw, 5rem);
  }

  .projects-header {
    padding-block: 0 2.5rem;
  }

  /* ── Track ────────────────────────────────────────────── */
  .projects-outer {
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    cursor: grab;
    padding-block: 0.5rem 1.25rem;
    /* Native smooth scroll for keyboard/programmatic scrolls. Drag still uses
       direct scrollLeft updates so it stays 1:1 with the pointer. */
    scroll-behavior: smooth;
  }
  .projects-outer::-webkit-scrollbar { display: none; }
  .projects-outer.is-dragging { cursor: grabbing; user-select: none; }

  .projects-track {
    display: flex;
    gap: clamp(1.75rem, 3vw, 2.75rem);
    align-items: flex-start;
    padding-inline: calc(max(1.5rem, (100vw - 1120px) / 2 + 1.5rem));
    width: max-content;
    will-change: transform;
  }

  .track-end {
    flex-shrink: 0;
    width: calc(max(1.5rem, (100vw - 1120px) / 2 + 1.5rem) - clamp(1.75rem, 3vw, 2.75rem));
  }

  /* ── Card ─────────────────────────────────────────────── */
  .project-card {
    flex-shrink: 0;
    /* Wide enough that the longest terminal line (~40 chars at 0.8rem mono)
       fits without truncating. Caps at 380px so 3 cards comfortably show on
       a typical desktop. */
    width: clamp(300px, 26vw, 380px);
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  /* The dark terminal window IS the visual card */
  .pcard-win {
    width: 100%;
    /* 4:3 aspect ratio */
    aspect-ratio: 4 / 3;
    background: oklch(0.13 0.022 255);
    border-radius: var(--radius-lg);
    border: 1px solid oklch(0.24 0.014 260);
    overflow: hidden;
    position: relative;
    display: flex;
    flex-direction: column;
    transition:
      border-color 180ms var(--ease-out-quart),
      box-shadow   180ms var(--ease-out-quart),
      transform    180ms var(--ease-out-quart);
  }
  .project-card:hover .pcard-win {
    border-color: color-mix(in oklch, var(--color-accent) 55%, oklch(0.24 0.014 260));
    box-shadow:
      0 0 0 2px color-mix(in oklch, var(--color-accent) 22%, transparent),
      0 12px 36px -12px color-mix(in oklch, var(--color-ink) 22%, transparent);
    transform: translateY(-3px);
  }

  /* Traffic lights bar */
  .pcard-bar {
    display: flex;
    align-items: center;
    gap: 5px;
    padding: 10px 13px 8px;
    border-bottom: 1px solid oklch(0.20 0.012 260);
    flex-shrink: 0;
  }
  .dot {
    width: 9px;
    height: 9px;
    border-radius: 50%;
    flex-shrink: 0;
  }

  /* Week chip — floating badge top-right */
  .week-chip {
    position: absolute;
    top: 8px;
    right: 10px;
    background: color-mix(in oklch, var(--color-accent) 25%, oklch(0.13 0.022 255));
    color: oklch(0.72 0.12 245);
    border: 1px solid color-mix(in oklch, var(--color-accent) 40%, transparent);
    padding: 0.15rem 0.5rem;
    border-radius: var(--radius-pill);
    font-family: ui-monospace, monospace;
    font-size: 0.62rem;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    font-weight: 500;
    pointer-events: none;
  }

  /* Terminal output */
  .pcard-body {
    padding: 12px 14px 14px;
    flex: 1;
    overflow: hidden;
  }
  .tl {
    font-family: ui-monospace, "SFMono-Regular", "Cascadia Mono", monospace;
    font-size: 0.78rem;
    line-height: 1.65;
    color: oklch(0.83 0.015 78);
    white-space: pre;
    letter-spacing: 0.008em;
  }
  .tl-cmd { color: oklch(0.70 0.14 245); font-weight: 600; }
  .tl-ok  { color: oklch(0.67 0.17 145); }
  .tl-sys { color: oklch(0.48 0.012 260); }

  /* ── Label (Dribbble-style below-card caption) ────────── */
  .pcard-label {
    padding-inline: 2px;
  }
  .pcard-title {
    font-family: var(--font-display);
    font-size: var(--text-base);
    font-weight: 600;
    color: var(--color-ink);
    line-height: 1.2;
    letter-spacing: -0.005em;
  }
  .pcard-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.35rem 0.6rem;
    list-style: none;
    padding: 0;
    margin-top: 0.5rem;
  }
  .pcard-tags li {
    font-size: var(--text-xs);
    color: var(--color-ink-mute);
  }
  /* bullet separator between tags */
  .pcard-tags li + li::before {
    content: "·";
    margin-right: 0.6rem;
    color: var(--color-rule-strong);
  }

  /* ── Scroll hint ──────────────────────────────────────── */
  .scroll-hint-row {
    padding-inline: calc(max(1.5rem, (100vw - 1120px) / 2 + 1.5rem));
    padding-block: 1.25rem 0;
  }
  .scroll-hint-row span {
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
    font-size: var(--text-xs);
    color: var(--color-ink-mute);
    letter-spacing: 0.05em;
  }
  @media (prefers-reduced-motion: reduce) {
    .scroll-hint-row { display: none; }
  }
</style>

<script>
  import gsap from "gsap";
  import ScrollTrigger from "gsap/ScrollTrigger";

  gsap.registerPlugin(ScrollTrigger);

  const section = document.querySelector<HTMLElement>(".projects-section");
  const outer   = document.querySelector<HTMLElement>(".projects-outer");
  const track   = document.querySelector<HTMLElement>(".projects-track");

  if (!section || !outer || !track) {
    throw new Error("ProjectsGallery: missing elements");
  }

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;
  const usePin  = window.matchMedia(
    "(min-width: 900px) and (prefers-reduced-motion: no-preference)"
  ).matches;

  type LenisLike = {
    on: (event: string, cb: () => void) => void;
    scrollTo: (target: number, opts?: { immediate?: boolean; duration?: number }) => void;
    scroll: number;
  };

  // Wire Lenis → ScrollTrigger. Lenis updates `window.scrollY` on every tick,
  // and ScrollTrigger reads from that — so this hookup makes the pin animation
  // respond to Lenis's smoothed scroll position. Without it the pin can feel
  // laggy because ScrollTrigger only refreshes on native scroll events that
  // Lenis has swallowed.
  const attachLenis = () => {
    const lenis = (window as unknown as { lenis?: LenisLike }).lenis;
    if (lenis) {
      lenis.on("scroll", ScrollTrigger.update);
      return lenis;
    }
    return null;
  };
  let lenis: LenisLike | null = attachLenis();
  if (!lenis) {
    window.addEventListener(
      "load",
      () => { lenis = attachLenis(); },
      { once: true }
    );
  }

  // ── Pin mode (desktop) ───────────────────────────────────
  // Vertical scroll inside the section becomes horizontal movement of the
  // track. The page itself pauses while the gallery scrolls, then resumes
  // once the user has wheeled past the last card.
  if (usePin) {
    // When pinned, the outer must not have its own horizontal scroll — the
    // track's `x` transform drives everything.
    outer.style.overflow = "hidden";
    outer.style.cursor = "grab";

    const totalScroll = () => Math.max(0, track.scrollWidth - outer.clientWidth);

    gsap.to(track, {
      x: () => -totalScroll(),
      ease: "none",
      scrollTrigger: {
        id: "projects-pin",
        trigger: section,
        start: "top top",
        end: () => `+=${totalScroll()}`,
        pin: true,
        // `scrub: true` = direct 1:1 mapping. Lenis already smooths the
        // underlying scroll position, so adding GSAP smoothing on top
        // (e.g. scrub: 1.2) introduces visible lag.
        scrub: true,
        anticipatePin: 1,
        invalidateOnRefresh: true,
      },
    });

    // Drag inside the pinned gallery → advance the page scroll. The pin
    // animation then translates that into horizontal track movement.
    let dragging = false;
    let lastX = 0;

    outer.addEventListener("pointerdown", (e) => {
      if (e.button !== undefined && e.button !== 0) return;
      dragging = true;
      lastX = e.clientX;
      outer.classList.add("is-dragging");
      outer.setPointerCapture(e.pointerId);
    });

    outer.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const dx = e.clientX - lastX;
      lastX = e.clientX;
      // Drag right by 1px ⇒ scroll page up by 1px (track moves right).
      if (lenis) {
        lenis.scrollTo(lenis.scroll - dx, { immediate: true });
      } else {
        window.scrollBy(0, -dx);
      }
    });

    const endDrag = () => {
      dragging = false;
      outer.classList.remove("is-dragging");
    };
    outer.addEventListener("pointerup", endDrag);
    outer.addEventListener("pointercancel", endDrag);
    outer.addEventListener("pointerleave", endDrag);

    // Keyboard: step the page scroll by a card-width's worth of pin range.
    outer.addEventListener("keydown", (e) => {
      const step = outer.clientWidth * 0.7;
      if (e.key === "ArrowRight" || e.key === "ArrowDown") {
        e.preventDefault();
        if (lenis) lenis.scrollTo(lenis.scroll + step);
        else window.scrollBy({ top: step, behavior: "smooth" });
      } else if (e.key === "ArrowLeft" || e.key === "ArrowUp") {
        e.preventDefault();
        if (lenis) lenis.scrollTo(lenis.scroll - step);
        else window.scrollBy({ top: -step, behavior: "smooth" });
      }
    });
  } else {
    // ── Mobile / reduced-motion fallback ───────────────────
    // Plain native overflow-x scroll with drag + momentum.
    let dragging = false;
    let startX = 0;
    let startLeft = 0;
    let lastX = 0;
    let lastT = 0;
    let velocity = 0;
    let rafId = 0;

    outer.addEventListener("pointerdown", (e) => {
      if (e.button !== undefined && e.button !== 0) return;
      dragging = true;
      startX = e.clientX;
      lastX = e.clientX;
      lastT = performance.now();
      startLeft = outer.scrollLeft;
      velocity = 0;
      if (rafId) {
        cancelAnimationFrame(rafId);
        rafId = 0;
      }
      outer.classList.add("is-dragging");
      outer.setPointerCapture(e.pointerId);
    });

    outer.addEventListener("pointermove", (e) => {
      if (!dragging) return;
      const now = performance.now();
      const dx = e.clientX - lastX;
      const dt = Math.max(1, now - lastT);
      velocity = dx / dt;
      lastX = e.clientX;
      lastT = now;
      outer.scrollLeft = startLeft - (e.clientX - startX);
    });

    const endDrag = () => {
      if (!dragging) return;
      dragging = false;
      outer.classList.remove("is-dragging");
      if (reduced || Math.abs(velocity) < 0.05) return;

      let v = -velocity * 16;
      const friction = 0.94;
      const step = () => {
        outer.scrollLeft += v;
        v *= friction;
        if (Math.abs(v) > 0.5) {
          rafId = requestAnimationFrame(step);
        } else {
          rafId = 0;
        }
      };
      rafId = requestAnimationFrame(step);
    };
    outer.addEventListener("pointerup", endDrag);
    outer.addEventListener("pointercancel", endDrag);
    outer.addEventListener("pointerleave", endDrag);

    outer.addEventListener("keydown", (e) => {
      const step = outer.clientWidth * 0.8;
      if (e.key === "ArrowRight") {
        e.preventDefault();
        outer.scrollBy({ left: step, behavior: "smooth" });
      } else if (e.key === "ArrowLeft") {
        e.preventDefault();
        outer.scrollBy({ left: -step, behavior: "smooth" });
      }
    });
  }
</script>
