---
import Base from "@layouts/Base.astro";
import { COHORT } from "@lib/data/cohort";

const orderId = Astro.url.searchParams.get("order_id") ?? null;
---

<Base
  title="You're booked · Build Space"
  description="Your demo class with Build Space is confirmed. We will be in touch with the session details shortly."
  noIndex
>
  <main
    id="main"
    class="container-page section-pad-lg"
    style="min-height: 80vh; display: grid; align-content: center;"
  >
    <div class="max-w-2xl">
      <p class="eyebrow" style="color: var(--color-good);">
        <span
          aria-hidden="true"
          class="mr-2 inline-block h-1.5 w-1.5 rounded-full align-middle"
          style="background: var(--color-good);"
        ></span>
        Payment confirmed
      </p>

      <h1
        class="mt-5"
        style={`font-family: var(--font-display); font-size: var(--text-4xl); line-height: 1.05; letter-spacing: -0.03em; font-weight: 600;`}
      >
        Your demo class is booked.
      </h1>

      <p
        class="mt-6 max-w-prose"
        style={`color: var(--color-ink-soft); font-size: var(--text-lg); line-height: 1.55;`}
      >
        We received your ₹99. The instructor will reach out on WhatsApp and email within one working day with the session date, the join link, and a short pre-class checklist for your child.
      </p>

      {orderId && (
        <p
          class="mt-6"
          style={`color: var(--color-ink-mute); font-size: var(--text-sm); font-family: var(--font-mono, ui-monospace, monospace);`}
        >
          Order reference: <span style="color: var(--color-ink);">{orderId}</span>
        </p>
      )}

      <div
        class="mt-10 rounded-[var(--radius-md)] border p-5"
        style="border-color: var(--color-rule); background: var(--color-paper-card);"
      >
        <p
          style={`font-family: var(--font-display); font-size: var(--text-base); font-weight: 600;`}
        >
          What happens next
        </p>
        <ol
          class="mt-3 grid gap-2"
          style={`color: var(--color-ink-soft); font-size: var(--text-sm); line-height: 1.55; padding-left: 1.1rem;`}
        >
          <li>You receive a confirmation email at the address you entered.</li>
          <li>The instructor sends a WhatsApp message with the join link.</li>
          <li>Your child attends the live demo class &mdash; two hours, online.</li>
          <li>If it is the right fit, you enrol in the full cohort. If not, you have spent ₹99.</li>
        </ol>
      </div>

      <div class="mt-9 flex flex-wrap items-center gap-3">
        <a href="/" class="btn btn-primary">Back to home</a>
        <a
          href={`mailto:${COHORT.contact.email}`}
          class="btn btn-secondary"
        >
          Email the instructor
        </a>
      </div>
    </div>
  </main>
</Base>

<script>
  // Read the variant that was stored before Razorpay redirect wiped the URL params.
  const adVariant = (() => {
    try { return sessionStorage.getItem("bs_ad_variant") || "direct"; }
    catch { return "direct"; }
  })();

  // ── Google Tag Manager dataLayer (works with any GTM-connected platform) ──
  (window as unknown as { dataLayer: unknown[] }).dataLayer =
    (window as unknown as { dataLayer: unknown[] }).dataLayer || [];
  (window as unknown as { dataLayer: unknown[] }).dataLayer.push({
    event: "demo_booked",
    ad_variant: adVariant,
    currency: "INR",
    value: 99,
  });

  // ── Meta Pixel ──
  if (typeof (window as unknown as { fbq?: Function }).fbq === "function") {
    const fbq = (window as unknown as { fbq: Function }).fbq;
    fbq("track", "Purchase", { currency: "INR", value: 99, content_name: "Logic Labs Demo Class" });
    fbq("trackCustom", "DemoBooked", { ad_variant: adVariant });
  }

  // ── Google Ads — uncomment once gtag snippet is in <head> ──
  // gtag("event", "conversion", { send_to: "AW-XXXXX/YYYYY", value: 99, currency: "INR" });

  // Clear after firing — prevents stale variant re-firing on page refresh
  try { sessionStorage.removeItem("bs_ad_variant"); } catch {}
</script>
