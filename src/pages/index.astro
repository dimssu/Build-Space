---
export const prerender = false;

import Base from "@layouts/Base.astro";
import Nav from "@components/nav/Nav.astro";
import Hero from "@components/hero/Hero.astro";
import Validation from "@components/validation/Validation.astro";
import Promise from "@components/promise/Promise.astro";
import Compare from "@components/compare/Compare.astro";
import Curriculum from "@components/curriculum/Curriculum.astro";
import Instructor from "@components/instructor/Instructor.astro";
import ScholarshipBanner from "@components/scholarship/ScholarshipBanner.astro";
import HowItWorks from "@components/how/HowItWorks.astro";
import CompareTable from "@components/vs/CompareTable.astro";
import Pricing from "@components/pricing/Pricing.astro";
import FAQ from "@components/faq/FAQ.astro";
import SocialProof from "@components/social/SocialProof.astro";
import ProjectsGallery from "@components/projects/ProjectsGallery.astro";
import ClosingCTA from "@components/cta/ClosingCTA.astro";
import Footer from "@components/footer/Footer.astro";
import { getVariant } from "@lib/data/variants";
import type { SectionKey } from "@lib/data/variants";

// Resolve the variant from the `?ad=` query param. `getVariant()` accepts
// `string | null | undefined` and falls back to the default variant when the
// slug is missing or unknown — so paid traffic that lands without a param
// (or with a stale one) still renders cleanly.
const adParam = Astro.url.searchParams.get("ad");
const variant = getVariant(adParam);
const title = variant.seo.title;
const description = variant.seo.description;

// Per-variant cache: short s-maxage so paid traffic gets fresh content,
// but the CDN can still cache hot ad URLs for the duration of a campaign burst.
Astro.response.headers.set("Cache-Control", "public, max-age=0, s-maxage=300, stale-while-revalidate=60");
Astro.response.headers.set("Vary", "Accept-Encoding");

// Map a SectionKey to the actual component. Hero and ClosingCTA stay outside
// this map — they are the visual anchors of the page (always first, always
// last). Everything in between is reorderable per variant.
const SECTIONS = {
  validation: Validation,
  promise: Promise,
  compare: Compare,
  curriculum: Curriculum,
  projects: ProjectsGallery,
  instructor: Instructor,
  testimonials: SocialProof,
  scholarship: ScholarshipBanner,
  howItWorks: HowItWorks,
  compareTable: CompareTable,
  pricing: Pricing,
  faq: FAQ,
} satisfies Record<SectionKey, unknown>;

// Default flow — mirrors the original hand-written order.
const DEFAULT_ORDER: SectionKey[] = [
  "validation",
  "promise",
  "compare",
  "curriculum",
  "projects",
  "instructor",
  "testimonials",
  "scholarship",
  "howItWorks",
  "compareTable",
  "pricing",
  "faq",
];

const middleOrder = variant.sectionOrder ?? DEFAULT_ORDER;
---

<!-- Store variant slug so it survives the Razorpay redirect to /success -->
<script define:vars={{ variantSlug: variant.slug }}>
  try { sessionStorage.setItem("bs_ad_variant", variantSlug); } catch {}
</script>

<Base {title} {description} variant={variant}>
  <Nav variant={variant} />

  <main id="main">
    <Hero variant={variant} />
    {middleOrder.map((key) => {
      const Section = SECTIONS[key];
      return <Section variant={variant} />;
    })}
    <ClosingCTA variant={variant} />
  </main>

  <Footer variant={variant} />
</Base>
